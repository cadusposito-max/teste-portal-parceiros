# Cabecalhos de seguranca HTTP — compativel com Netlify e Cloudflare Pages

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-XSS-Protection: 1; mode=block
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  # frame-ancestors via HTTP header — meta CSP ignora este directive (spec W3C)
  Content-Security-Policy: frame-ancestors 'none'
  # Protecao contra ataques Spectre/cross-origin (COOP)
  Cross-Origin-Opener-Policy: same-origin

/proposta.html
  Cache-Control: no-store, max-age=0
  X-Robots-Tag: noindex, nofollow, noarchive
  Content-Security-Policy: frame-ancestors 'none'

/proposta-mobile.html
  Cache-Control: no-store, max-age=0
  X-Robots-Tag: noindex, nofollow, noarchive
  Content-Security-Policy: frame-ancestors 'none'

/proposta-desktop.html
  Cache-Control: no-store, max-age=0
  X-Robots-Tag: noindex, nofollow, noarchive
  Content-Security-Policy: frame-ancestors 'none'

/proposta-print.html
  Cache-Control: no-store, max-age=0
