/* ==========================================
   ESTILOS GLOBAIS — Ágil Solar Portal
   ========================================== */

body {
  background-color: #050505;
  color: #e5e5e5;
}

/* ==========================================
   LOGO — glow only in dark mode
   ========================================== */
img[data-theme-logo="true"] {
  filter: drop-shadow(0 0 22px rgba(249,115,22,0.4));
}

/* ==========================================
   SCROLLBARS
   ========================================== */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: #0a0a0a; }
::-webkit-scrollbar-thumb { background: #2a2a2a; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #f97316; }

.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

.custom-scrollbar::-webkit-scrollbar { width: 6px; }
.custom-scrollbar::-webkit-scrollbar-track { background: #171717; border-radius: 4px; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 4px; }
.custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #f97316; }

/* ==========================================
   GRADIENT BORDER (proposta.html legacy)
   ========================================== */
.gradient-border {
  position: relative;
  background: #050505;
  background-clip: padding-box;
  border: solid 2px transparent;
  border-radius: 1rem;
}
.gradient-border:before {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  z-index: -1;
  margin: -2px;
  border-radius: inherit;
  background: linear-gradient(to right, #ea580c, #eab308);
}

/* ==========================================
   BACKGROUND GRID PATTERN
   ========================================== */
.bg-grid {
  background-image:
    linear-gradient(rgba(255,255,255,0.018) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.018) 1px, transparent 1px);
  background-size: 44px 44px;
}
.bg-grid-sm {
  background-image:
    linear-gradient(rgba(255,255,255,0.012) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.012) 1px, transparent 1px);
  background-size: 22px 22px;
}

/* ==========================================
   METRIC CARDS — Premium glassmorphism
   ========================================== */
.metric-card {
  background: linear-gradient(145deg, rgba(22,22,26,0.92) 0%, rgba(14,14,16,0.75) 60%, rgba(10,10,12,0.85) 100%);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-color: rgba(255,255,255,0.06) !important;
  border-radius: 16px !important;
  box-shadow:
    0 4px 24px rgba(0,0,0,0.45),
    inset 0 1px 0 rgba(255,255,255,0.07),
    inset 1px 0 0 rgba(255,255,255,0.03);
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.35s ease,
              border-color 0.35s ease;
}
.metric-card:hover {
  transform: translateY(-3px);
  box-shadow:
    0 12px 40px rgba(0,0,0,0.55),
    0 0 0 1px rgba(249,115,22,0.1),
    inset 0 1px 0 rgba(255,255,255,0.1) !important;
}

/* ==========================================
   SHINE SWEEP — light pass on hover
   ========================================== */
.shine-effect {
  position: relative;
  overflow: hidden;
}
.shine-effect::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -80%;
  width: 35%;
  height: 200%;
  background: linear-gradient(
    to right,
    transparent 0%,
    rgba(255,255,255,0.035) 50%,
    transparent 100%
  );
  transform: skewX(-15deg);
  transition: left 0.6s ease;
  pointer-events: none;
}
.shine-effect:hover::after {
  left: 140%;
}

/* ==========================================
   STAGGER ENTRY ANIMATIONS
   ========================================== */
.stagger-1 { animation: fadeSlideUp 0.5s ease-out both; animation-delay: 0ms; }
.stagger-2 { animation: fadeSlideUp 0.5s ease-out both; animation-delay: 80ms; }
.stagger-3 { animation: fadeSlideUp 0.5s ease-out both; animation-delay: 160ms; }
.stagger-4 { animation: fadeSlideUp 0.5s ease-out both; animation-delay: 240ms; }
.stagger-5 { animation: fadeSlideUp 0.5s ease-out both; animation-delay: 320ms; }
.stagger-6 { animation: fadeSlideUp 0.5s ease-out both; animation-delay: 400ms; }

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ==========================================
   ANIMATED PROGRESS BAR FILL
   ========================================== */
@keyframes bar-fill {
  from { width: 0 !important; }
}
.bar-animated {
  animation: bar-fill 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}
.bar-animated.delay-150 { animation-delay: 150ms; }
.bar-animated.delay-300 { animation-delay: 300ms; }
.bar-animated.delay-450 { animation-delay: 450ms; }

/* ==========================================
   FUNNEL BARS
   ========================================== */
@keyframes funnel-slide {
  from { width: 0 !important; opacity: 0; }
  to   { opacity: 1; }
}
.funnel-bar {
  animation: funnel-slide 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

/* ==========================================
   NUMBER POP (counter animation element)
   ========================================== */
@keyframes number-pop {
  0%   { opacity: 0; transform: scale(0.75) translateY(6px); }
  70%  { transform: scale(1.04) translateY(-1px); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}
.number-pop {
  animation: number-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* ==========================================
   TABLE ROW — premium hover
   ========================================== */
.table-row-hover {
  transition: background 0.2s ease, border-left-color 0.2s ease;
}
.table-row-hover:hover {
  background: linear-gradient(90deg, rgba(249,115,22,0.04) 0%, transparent 60%);
  border-left-color: rgba(249,115,22,0.4) !important;
}

/* ==========================================
   LIVE CLOCK
   ========================================== */
.live-clock {
  font-variant-numeric: tabular-nums;
  font-feature-settings: 'tnum';
  letter-spacing: 0.02em;
}

/* ==========================================
   NEON GLOW TEXT
   ========================================== */
.neon-green {
  text-shadow: 0 0 14px rgba(34,197,94,0.45), 0 0 28px rgba(34,197,94,0.15);
}
.neon-orange {
  text-shadow: 0 0 14px rgba(249,115,22,0.45), 0 0 28px rgba(249,115,22,0.15);
}

/* ==========================================
   USER AVATAR PULSE
   ========================================== */
@keyframes avatar-ring {
  0%, 100% { box-shadow: 0 0 0 0 rgba(249,115,22,0.4); }
  50%       { box-shadow: 0 0 0 4px rgba(249,115,22,0); }
}
.avatar-pulse {
  animation: avatar-ring 3s ease-in-out infinite;
}

/* ==========================================
   HEADER TOP STRIPE SLIDE
   ========================================== */
@keyframes stripe-slide {
  from { background-position: 0 0; }
  to   { background-position: 200px 0; }
}
.animated-stripe {
  background: repeating-linear-gradient(
    90deg,
    #ea580c 0px,
    #f97316 20px,
    #eab308 40px,
    #f97316 60px,
    #ea580c 80px
  );
  background-size: 200px 100%;
  animation: stripe-slide 4s linear infinite;
}

/* ==========================================
   TAB — active underline indicator
   ========================================== */
.tab-active-underline {
  position: relative;
}
.tab-active-underline::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 8px;
  right: 8px;
  height: 2px;
  background: linear-gradient(to right, #ea580c, #eab308);
  border-radius: 1px;
}

/* ==========================================
   CARD SECTION HEADER ACCENT
   ========================================== */
.section-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border: 1px solid;
  flex-shrink: 0;
}

/* ==========================================
   MODAL BACKDROP BLUR TRANSITION
   ========================================== */
.modal-enter {
  animation: modalIn 0.25s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes modalIn {
  from { opacity: 0; transform: scale(0.96) translateY(8px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

/* ==========================================
   TOAST REDESIGN
   ========================================== */
#toast {
  backdrop-filter: blur(16px);
}



/* ==========================================
   VERSION UPDATE NOTICE
   ========================================== */
#version-update-notice,
#version-update-notice * {
  box-sizing: border-box;
}

#version-update-notice {
  position: fixed;
  left: 24px;
  right: auto;
  bottom: 24px;
  width: clamp(360px, 31vw, 420px);
  max-width: calc(100vw - 48px);
  z-index: 10000;
  border: 1px solid rgba(249, 115, 22, 0.55);
  border-radius: 14px;
  background: rgba(10, 10, 10, 0.96);
  box-shadow: 0 12px 36px rgba(249, 115, 22, 0.24);
  backdrop-filter: blur(8px);
  padding: 16px;
  opacity: 0;
  transform: translateY(12px);
  pointer-events: none;
  transition: opacity 0.25s ease, transform 0.25s ease;
  color: #ffffff;
}

#version-update-notice.is-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

#version-update-notice .version-update-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

#version-update-notice .version-update-icon-wrap {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border: 1px solid rgba(249, 115, 22, 0.35);
  background: rgba(249, 115, 22, 0.12);
  flex-shrink: 0;
  border-radius: 10px;
}

#version-update-notice .version-update-icon {
  width: 18px;
  height: 18px;
  color: #fb923c;
  stroke-width: 2.4;
}

#version-update-notice .version-update-copy {
  min-width: 0;
  flex: 1;
}

#version-update-notice .version-update-title {
  margin: 0;
  color: #ffffff;
  font-size: 16px;
  line-height: 1.3;
  font-weight: 900;
  letter-spacing: 0.01em;
}

#version-update-notice .version-update-text {
  margin: 6px 0 0;
  color: #d4d4d4;
  font-size: 13px;
  line-height: 1.45;
  font-weight: 500;
}

#version-update-notice .version-update-actions {
  margin-top: 14px;
  display: flex;
  align-items: center;
  gap: 10px;
}

#version-update-notice .version-update-btn {
  border: 0;
  border-radius: 10px;
  padding: 11px 14px;
  cursor: pointer;
  font-weight: 900;
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: filter 0.2s ease, transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
}

#version-update-notice .version-update-btn:disabled {
  cursor: not-allowed;
  opacity: 0.8;
}

#version-update-notice .version-update-btn-primary {
  flex: 1;
  color: #090909;
  background: linear-gradient(90deg, #ea580c, #facc15);
}

#version-update-notice .version-update-btn-primary:hover {
  filter: brightness(1.06);
}

#version-update-notice .version-update-btn-secondary {
  min-width: 104px;
  color: #ffffff;
  background: #262626;
  border: 1px solid #404040;
}

#version-update-notice .version-update-btn-secondary:hover {
  background: #303030;
  border-color: #525252;
}

@media (max-width: 760px) {
  #version-update-notice {
    left: 12px;
    right: 12px;
    bottom: 12px;
    width: auto;
    max-width: none;
    border-radius: 12px;
    padding: 14px;
  }

  #version-update-notice .version-update-title {
    font-size: 15px;
  }

  #version-update-notice .version-update-text {
    font-size: 12px;
  }
}

@media (max-width: 520px) {
  #version-update-notice .version-update-actions {
    display: grid;
    grid-template-columns: 1fr;
  }

  #version-update-notice .version-update-btn-secondary {
    width: 100%;
    min-width: 0;
  }
}

/* ==========================================
   HOVER LIFT — generic
   ========================================== */
.hover-lift {
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s ease;
}
.hover-lift:hover {
  transform: translateY(-2px);
}

/* ==========================================
   PERFORMANCE — mobile/reduced motion
   ========================================== */
@media (prefers-reduced-motion: reduce), (max-width: 768px) {
  .stagger-1,
  .stagger-2,
  .stagger-3,
  .stagger-4,
  .stagger-5,
  .stagger-6,
  .bar-animated,
  .funnel-bar,
  .number-pop,
  .avatar-pulse {
    animation: none !important;
  }
}

/* animated-stripe: desativa só para reduced-motion, NÃO no mobile */
@media (prefers-reduced-motion: reduce) {
  .animated-stripe {
    animation: none !important;
  }

  .metric-card,
  .hover-lift,
  .table-row-hover {
    transition: none !important;
  }

  #toast {
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }
}

/* ==========================================
   VIDEO CAROUSEL ARROWS
   ========================================== */
.vid-nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: rgba(20, 20, 20, 0.85);
  border: 1.5px solid rgba(255, 255, 255, 0.25);
  color: #ffffff;
  box-shadow: 0 2px 8px rgba(0,0,0,0.5);
  transition: background 0.2s ease, transform 0.15s ease;
  cursor: pointer;
}
.vid-nav-btn:hover {
  background: #2563eb;
  border-color: #2563eb;
  transform: scale(1.1);
}

/* ==========================================
   CHAT UI — Internal Messenger
   ========================================== */
:root {
  --chat-bg: #090909;
  --chat-panel: #0f0f10;
  --chat-muted: #9ca3af;
  --chat-border: #2a2a2b;
  --chat-accent: #f97316;
  --chat-accent-2: #eab308;
  --chat-text: #f5f5f5;
  --chat-me: #1f2937;
  --chat-other: #111827;
}

body.theme-light {
  --chat-bg: #eef2f7;
  --chat-panel: #ffffff;
  --chat-muted: #64748b;
  --chat-border: #d6dde8;
  --chat-accent: #2563eb;
  --chat-accent-2: #60a5fa;
  --chat-text: #0f172a;
  --chat-me: #dbeafe;
  --chat-other: #f1f5f9;
}

.chat-fab-btn {
  width: 64px;
  height: 64px;
  border-radius: 999px;
  border: 1px solid rgba(249,115,22,0.5);
  background: linear-gradient(135deg, var(--chat-accent), var(--chat-accent-2));
  color: #0b0b0c;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 28px rgba(249,115,22,0.35);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.chat-fab-btn:hover {
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 0 34px rgba(249,115,22,0.45);
}

.chat-fab-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 22px;
  height: 22px;
  border-radius: 999px;
  background: #ef4444;
  color: #fff;
  font-size: 10px;
  font-weight: 900;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 2px solid #0a0a0a;
  padding: 0 5px;
}

#chat-shell {
  pointer-events: none;
}

#chat-shell.chat-shell--desktop,
#chat-shell.chat-shell--mobile {
  pointer-events: auto;
}

#chat-shell.chat-shell--desktop {
  right: 24px;
  bottom: 96px;
  width: min(92vw, 920px);
  height: min(80vh, 680px);
}

#chat-shell.chat-shell--mobile {
  inset: 0;
  width: 100vw;
  height: 100dvh;
}

.chat-shell-window {
  position: relative;
  width: 100%;
  height: 100%;
  background: var(--chat-bg);
  border: 1px solid var(--chat-border);
  box-shadow: 0 20px 60px rgba(0,0,0,0.45);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.chat-shell--desktop .chat-shell-window {
  border-radius: 14px;
}

.chat-shell--mobile .chat-shell-window {
  border-radius: 0;
  border: none;
}

.chat-shell-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 14px;
  border-bottom: 1px solid var(--chat-border);
  background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(0,0,0,0));
}

.chat-shell-header-left {
  position: relative;
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
}

.chat-shell-header-title-wrap {
  min-width: 0;
}

.chat-thread-meta-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  min-width: 0;
  border: 1px solid transparent;
  background: transparent;
  color: inherit;
  padding: 0;
  border-radius: 10px;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.chat-thread-meta-btn.is-clickable:hover {
  border-color: var(--chat-border);
  background: rgba(255,255,255,0.03);
}

.chat-thread-meta-btn[disabled] {
  cursor: default;
}

.chat-thread-avatar,
.chat-profile-avatar {
  display: inline-flex;
  flex-shrink: 0;
}

.chat-shell-overline {
  color: var(--chat-muted);
  font-size: 10px;
  font-weight: 900;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.chat-shell-title {
  color: var(--chat-text);
  font-size: 15px;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-shell-subtitle {
  color: var(--chat-muted);
  font-size: 11px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-shell-header-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.chat-thread-profile-card {
  position: absolute;
  top: calc(100% + 10px);
  left: 44px;
  width: min(320px, calc(100vw - 28px));
  border: 1px solid var(--chat-border);
  background: var(--chat-panel);
  padding: 10px;
  z-index: 8;
  box-shadow: 0 14px 32px rgba(0,0,0,0.35);
}

.chat-thread-profile-top {
  display: flex;
  align-items: center;
  gap: 10px;
  padding-bottom: 10px;
  border-bottom: 1px solid var(--chat-border);
}

.chat-thread-profile-main {
  min-width: 0;
}

.chat-thread-profile-name {
  font-size: 13px;
  font-weight: 900;
  color: var(--chat-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-thread-profile-kind {
  font-size: 10px;
  font-weight: 800;
  color: var(--chat-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.chat-thread-profile-grid {
  margin-top: 10px;
  display: grid;
  gap: 7px;
}

.chat-thread-profile-row {
  display: flex;
  justify-content: space-between;
  gap: 10px;
}

.chat-thread-profile-label {
  font-size: 10px;
  color: var(--chat-muted);
  text-transform: uppercase;
  letter-spacing: 0.07em;
}

.chat-thread-profile-value {
  font-size: 11px;
  color: var(--chat-text);
  font-weight: 800;
  text-align: right;
  max-width: 190px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-icon-btn {
  width: 34px;
  height: 34px;
  border: 1px solid var(--chat-border);
  background: var(--chat-panel);
  color: var(--chat-muted);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
}

.chat-icon-btn:hover {
  color: var(--chat-text);
  border-color: var(--chat-accent);
  transform: translateY(-1px);
}

.chat-shell-body {
  flex: 1;
  min-height: 0;
  display: grid;
  grid-template-columns: 320px 1fr;
}

.chat-list-panel {
  border-right: 1px solid var(--chat-border);
  background: var(--chat-panel);
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.chat-search-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  border-bottom: 1px solid var(--chat-border);
  color: var(--chat-muted);
}

.chat-search-wrap input {
  width: 100%;
  border: 1px solid var(--chat-border);
  background: transparent;
  color: var(--chat-text);
  padding: 8px 10px;
  font-size: 12px;
  font-weight: 700;
  outline: none;
}

.chat-search-wrap input:focus {
  border-color: var(--chat-accent);
}

.chat-list-empty,
.chat-thread-empty,
.chat-thread-no-messages {
  color: var(--chat-muted);
  font-size: 12px;
  font-weight: 700;
  text-align: center;
}

.chat-list-empty {
  padding: 18px 10px;
}

.chat-list-items,
.chat-directory-list {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 8px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.chat-conv-item {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  text-align: left;
  border: 1px solid transparent;
  background: transparent;
  color: var(--chat-text);
  padding: 10px;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.chat-conv-item:hover {
  border-color: var(--chat-border);
  background: rgba(255,255,255,0.02);
}

.chat-conv-item.is-active {
  border-color: rgba(249,115,22,0.35);
  background: rgba(249,115,22,0.08);
}

.chat-conv-avatar,
.chat-directory-avatar,
.chat-thread-avatar-core,
.chat-profile-avatar-core {
  width: 34px;
  height: 34px;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--chat-accent), var(--chat-accent-2));
  color: #0b0b0c;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 900;
  flex-shrink: 0;
  overflow: hidden;
}

.chat-thread-avatar-core,
.chat-profile-avatar-core {
  width: 36px;
  height: 36px;
}

.chat-conv-avatar.has-image,
.chat-thread-avatar-core.has-image,
.chat-profile-avatar-core.has-image {
  background: #0f1113;
  border: 1px solid var(--chat-border);
  color: transparent;
}

.chat-conv-avatar img,
.chat-thread-avatar-core img,
.chat-profile-avatar-core img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.chat-conv-main,
.chat-directory-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.chat-conv-top,
.chat-conv-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  min-width: 0;
}

.chat-conv-title,
.chat-directory-name {
  font-size: 12px;
  font-weight: 900;
  color: var(--chat-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-conv-time,
.chat-directory-meta {
  font-size: 10px;
  color: var(--chat-muted);
  white-space: nowrap;
}

.chat-conv-preview {
  font-size: 11px;
  color: var(--chat-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chat-conv-unread {
  min-width: 19px;
  height: 19px;
  border-radius: 999px;
  background: #ef4444;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 900;
  padding: 0 4px;
}

.chat-thread-panel {
  display: flex;
  flex-direction: column;
  min-height: 0;
  background: var(--chat-bg);
}

.chat-thread-empty {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 10px;
}

.chat-thread-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.chat-thread-loading {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 11px;
  font-weight: 700;
  color: var(--chat-muted);
  padding: 8px 12px;
  border-bottom: 1px solid var(--chat-border);
}

.chat-thread-messages {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.chat-msg-row {
  display: flex;
}

.chat-msg-row.is-me {
  justify-content: flex-end;
}

.chat-msg-row.is-other {
  justify-content: flex-start;
}

.chat-msg-bubble {
  max-width: min(78%, 520px);
  border: 1px solid var(--chat-border);
  background: var(--chat-other);
  color: var(--chat-text);
  padding: 8px 10px;
}

.chat-msg-row.is-me .chat-msg-bubble {
  background: var(--chat-me);
  border-color: rgba(99,102,241,0.25);
}

.chat-msg-sender {
  font-size: 10px;
  font-weight: 900;
  color: var(--chat-muted);
  margin-bottom: 4px;
}

.chat-msg-text {
  font-size: 13px;
  line-height: 1.45;
  word-break: break-word;
}

.chat-msg-meta {
  margin-top: 6px;
  font-size: 10px;
  color: var(--chat-muted);
  text-align: right;
}

.chat-thread-form {
  border-top: 1px solid var(--chat-border);
  padding: 10px;
  display: flex;
  align-items: flex-end;
  gap: 8px;
  background: var(--chat-panel);
}

.chat-thread-form textarea {
  flex: 1;
  resize: none;
  border: 1px solid var(--chat-border);
  background: transparent;
  color: var(--chat-text);
  padding: 8px 10px;
  min-height: 44px;
  max-height: 150px;
  font-size: 13px;
  outline: none;
}

.chat-thread-form textarea:focus {
  border-color: var(--chat-accent);
}

.chat-thread-form button {
  width: 42px;
  height: 42px;
  border: 1px solid var(--chat-border);
  background: linear-gradient(135deg, var(--chat-accent), var(--chat-accent-2));
  color: #0b0b0c;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease;
}

.chat-thread-form button:disabled {
  opacity: 0.45;
  cursor: not-allowed;
}

.chat-directory-overlay {
  position: absolute;
  inset: 0;
  background: rgba(5,5,5,0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px;
}

.chat-directory-card {
  width: min(560px, 96%);
  height: min(72%, 560px);
  background: var(--chat-bg);
  border: 1px solid var(--chat-border);
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.chat-directory-header {
  padding: 10px 12px;
  border-bottom: 1px solid var(--chat-border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.chat-directory-title {
  color: var(--chat-text);
  font-size: 12px;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.chat-directory-item {
  display: flex;
  align-items: center;
  gap: 10px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--chat-text);
  width: 100%;
  text-align: left;
  padding: 10px;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.chat-directory-item:hover {
  border-color: var(--chat-border);
  background: rgba(255,255,255,0.02);
}

@media (max-width: 1023px) {
  .chat-shell-header {
    padding-top: calc(12px + env(safe-area-inset-top));
  }

  .chat-shell-body {
    grid-template-columns: 1fr;
  }

  .chat-shell--mobile .chat-list-panel {
    border-right: none;
  }

  .chat-shell--mobile .chat-thread-panel {
    display: none;
  }

  .chat-shell--mobile.chat-shell--thread .chat-list-panel {
    display: none;
  }

  .chat-shell--mobile.chat-shell--thread .chat-thread-panel {
    display: flex;
  }

  .chat-fab-btn {
    width: 60px;
    height: 60px;
  }

  .chat-shell--mobile .chat-thread-form {
    padding-bottom: calc(10px + env(safe-area-inset-bottom));
  }

  .chat-thread-profile-card {
    left: 0;
    width: min(300px, calc(100vw - 22px));
  }
}


/* ==========================================
   PROPOSTA — Premium hero/cards/CTA
   ========================================== */
.proposal-hero-shell {
  position: relative;
  overflow: hidden;
  border-radius: 1rem;
  border: 1px solid rgba(249, 115, 22, 0.3);
  background:
    radial-gradient(120% 140% at 0% 0%, rgba(249, 115, 22, 0.16) 0%, rgba(249, 115, 22, 0) 58%),
    radial-gradient(90% 100% at 100% 0%, rgba(234, 179, 8, 0.14) 0%, rgba(234, 179, 8, 0) 55%),
    linear-gradient(170deg, #101011 0%, #090909 55%, #050505 100%);
  box-shadow: 0 0 46px rgba(234, 88, 12, 0.18);
}

.proposal-hero-shell::before {
  content: '';
  position: absolute;
  inset: -1px;
  pointer-events: none;
  background: linear-gradient(115deg, rgba(249, 115, 22, 0.35), rgba(234, 179, 8, 0.1), transparent 65%);
  opacity: 0.65;
}

.proposal-kpi-card {
  border: 1px solid rgba(115, 115, 115, 0.38);
  background: linear-gradient(180deg, rgba(10, 10, 10, 0.92), rgba(16, 16, 16, 0.78));
  border-radius: 0.9rem;
  padding: 0.85rem 0.95rem;
  min-height: 98px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 0.2rem;
}

.proposal-kpi-label {
  font-size: 0.62rem;
  font-weight: 900;
  letter-spacing: 0.11em;
  text-transform: uppercase;
  color: #9ca3af;
}

.proposal-kpi-value {
  font-size: clamp(1.05rem, 2vw, 1.45rem);
  font-weight: 900;
  letter-spacing: -0.02em;
  color: #f8fafc;
  line-height: 1.2;
}

.proposal-kpi-note {
  font-size: 0.72rem;
  color: #737373;
  font-weight: 700;
}

.proposal-inline-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.78rem 1.1rem;
  border-radius: 0.8rem;
  border: 1px solid rgba(249, 115, 22, 0.4);
  background: linear-gradient(135deg, #ea580c, #f59e0b);
  color: #0b0b0c;
  font-size: 0.72rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.09em;
  transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
  box-shadow: 0 0 26px rgba(234, 88, 12, 0.3);
}

.proposal-inline-cta:hover {
  transform: translateY(-1px);
  filter: brightness(1.03);
  box-shadow: 0 0 34px rgba(234, 88, 12, 0.4);
}

.proposal-inline-cta.is-secondary {
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.14), rgba(234, 179, 8, 0.13));
  border-color: rgba(249, 115, 22, 0.34);
  color: #f9fafb;
  box-shadow: none;
}

.proposal-inline-cta.is-secondary:hover {
  box-shadow: 0 0 24px rgba(234, 88, 12, 0.2);
}

@media (max-width: 768px) {
  .proposal-kpi-card {
    min-height: 84px;
    padding: 0.75rem 0.8rem;
  }

  .proposal-inline-cta {
    width: 100%;
  }
}

/* ============================================================
   PREMIUM RESTYLING v2 — Liquid Glass · Apple-Like
   Parceiros Ágil Solar — Deep visual upgrade
   Referência: versao_ios26.html
   Regra: VISUAL ONLY. Zero alteração funcional.
   Foco: materialidade, profundidade, composição.
   ============================================================ */

/* ─── 1. DESIGN TOKENS ──────────────────────────────────────── */
:root {
  /* Glass surfaces */
  --g-surf-1:    rgba(24, 24, 32, 0.94);
  --g-surf-2:    rgba(16, 16, 22, 0.78);
  --g-surf-3:    rgba(12, 12, 18, 0.88);

  /* Glass border & highlight */
  --g-border:    rgba(255, 255, 255, 0.072);
  --g-hi-top:    rgba(255, 255, 255, 0.12);   /* reflexo de topo (aresta de vidro) */
  --g-hi-side:   rgba(255, 255, 255, 0.045);
  --g-hi-bot:    rgba(0,   0,   0,   0.22);

  /* Depth layers */
  --g-d1: 0 1px 3px   rgba(0,0,0,0.28);
  --g-d2: 0 6px 20px  rgba(0,0,0,0.42);
  --g-d3: 0 20px 52px rgba(0,0,0,0.28);

  /* Brand */
  --br-o:    #f97316;
  --br-a:    #f59e0b;
  --br-glow: rgba(249,115,22,0.14);

  /* Radii */
  --r-xs: 8px;
  --r-sm: 12px;
  --r-md: 16px;
  --r-lg: 22px;
  --r-xl: 28px;
  --r-2xl: 36px;
}

/* ─── 2. BODY — atmosfera rica ──────────────────────────────── */
body {
  background-color: #09090c !important;
  background-image: none !important;
  overflow-x: hidden;
}

/* Glow ambiente superior-esquerdo (como o .bg-glow-tl da referência) */
body::before {
  content: '';
  position: fixed;
  top: -160px;
  left: -160px;
  width: 600px;
  height: 600px;
  background: radial-gradient(
    circle at center,
    rgba(249, 115, 22, 0.09) 0%,
    rgba(245, 158, 11, 0.04) 40%,
    transparent 70%
  );
  pointer-events: none;
  z-index: 0;
}

/* Glow ambiente inferior-direito */
body::after {
  content: '';
  position: fixed;
  bottom: -120px;
  right: -100px;
  width: 480px;
  height: 480px;
  background: radial-gradient(
    circle at center,
    rgba(234, 179, 8, 0.05) 0%,
    transparent 65%
  );
  pointer-events: none;
  z-index: 0;
}

/* Todo o conteúdo acima da atmosfera */
body > * { position: relative; z-index: 1; }

/* Sutil grade de fundo que reforça a profundidade */
#app-content::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.010) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.010) 1px, transparent 1px);
  background-size: 52px 52px;
  pointer-events: none;
  z-index: 0;
}

/* ─── 3. APP SHELL — sensação de produto premium ────────────── */
#app-content {
  position: relative;
  isolation: isolate;
}

/* main content: mais respiro vertical */
#app-content > main {
  padding-top:    2.25rem !important;
  padding-bottom: 3.5rem  !important;
}

@media (max-width: 768px) {
  #app-content > main {
    padding-top:    1rem   !important;
    padding-bottom: 2rem   !important;
  }
}

/* ─── 4. HEADER — vidro saturado premium ────────────────────── */
header.sticky {
  background: linear-gradient(
    180deg,
    rgba(11, 11, 17, 0.97) 0%,
    rgba(9,  9,  15, 0.92) 100%
  ) !important;
  backdrop-filter: saturate(180%) blur(32px) !important;
  -webkit-backdrop-filter: saturate(180%) blur(32px) !important;
  border-bottom: 1px solid rgba(255,255,255,0.055) !important;
  box-shadow:
    0  1px  0  rgba(255,255,255,0.040),   /* linha de reflexo no topo */
    0  2px  8px rgba(0,0,0,0.40),
    0  8px 36px rgba(0,0,0,0.30) !important;
}

/* Stripe do header — mais sutil, menos "gamer" */
.animated-stripe {
  opacity: 0.45 !important;
}

/* ─── 5. NAVIGATION TABS — pílulas glass (estilo sidebar da referência) */
#tab-container {
  background: rgba(255,255,255,0.035) !important;
  border: 1px solid rgba(255,255,255,0.065) !important;
  border-radius: var(--r-md) !important;
  padding: 3px !important;
  gap: 2px !important;
}

#tab-container button,
#tab-container a {
  border-radius: var(--r-sm) !important;
  font-size: 11px !important;
  letter-spacing: 0.04em !important;
  padding: 7px 14px !important;
  transition:
    background  0.20s ease,
    box-shadow  0.20s ease,
    color       0.20s ease !important;
}

/* Tab ativa — glass elevado como item de sidebar da referência */
#tab-container button.tab-active-underline,
#tab-container a.tab-active-underline {
  background: linear-gradient(
    148deg,
    rgba(255,255,255,0.14) 0%,
    rgba(255,255,255,0.08) 100%
  ) !important;
  color: #ffffff !important;
  box-shadow:
    0 1px 5px  rgba(0,0,0,0.35),
    0 3px 10px rgba(0,0,0,0.22),
    inset 0  1px 0 rgba(255,255,255,0.16),
    inset 0 -1px 0 rgba(0,0,0,0.22) !important;
}

/* Remove underline laranja — substituído pelo glass pill */
#tab-container button.tab-active-underline::after,
#tab-container a.tab-active-underline::after {
  display: none !important;
}

/* Menu mobile */
#mobile-menu {
  background: rgba(9,9,15,0.98) !important;
  backdrop-filter: blur(28px) !important;
  border-top-color: rgba(255,255,255,0.045) !important;
}

/* Header divider */
#header-user {
  border-left-color: rgba(255,255,255,0.06) !important;
}

/* ─── 6. METRIC CARDS — superfície de vidro escuro real ─────── */
.metric-card {
  background: linear-gradient(
    148deg,
    var(--g-surf-1) 0%,
    var(--g-surf-2) 52%,
    var(--g-surf-3) 100%
  ) !important;
  backdrop-filter: blur(20px) !important;
  -webkit-backdrop-filter: blur(20px) !important;
  border: 1px solid var(--g-border) !important;
  border-radius: var(--r-md) !important;
  box-shadow:
    var(--g-d1),
    var(--g-d2),
    var(--g-d3),
    inset 0  1px 0 var(--g-hi-top),    /* aresta de vidro superior */
    inset 1px 0  0 var(--g-hi-side),   /* aresta lateral */
    inset 0 -1px 0 var(--g-hi-bot) !important;
  transition:
    transform    0.30s cubic-bezier(0.34, 1.40, 0.64, 1),
    box-shadow   0.30s ease,
    border-color 0.30s ease !important;
}

.metric-card:hover {
  transform: translateY(-3px) !important;
  border-color: rgba(255,255,255,0.10) !important;
  box-shadow:
    0 2px   6px rgba(0,0,0,0.32),
    0 12px 36px rgba(0,0,0,0.52),
    0 32px 72px rgba(0,0,0,0.28),
    0  0    0  1px rgba(249,115,22,0.07),
    inset 0  1px 0 rgba(255,255,255,0.14),
    inset 1px 0  0 rgba(255,255,255,0.055) !important;
}

/* ─── 7. GLASS CARD — panel mais elevado ────────────────────── */
.glass-card {
  background: linear-gradient(
    148deg,
    rgba(28, 28, 36, 0.92) 0%,
    rgba(18, 18, 26, 0.68) 100%
  ) !important;
  backdrop-filter: blur(22px) !important;
  -webkit-backdrop-filter: blur(22px) !important;
  border: 1px solid var(--g-border) !important;
  border-radius: var(--r-lg) !important;
  box-shadow:
    0  4px  8px rgba(0,0,0,0.22),
    0 14px 42px rgba(0,0,0,0.46),
    0 36px 88px rgba(0,0,0,0.28),
    inset 0  1px 1px rgba(255,255,255,0.13),
    inset 1px 0  1px rgba(255,255,255,0.05),
    inset -1px -1px 1px rgba(0,0,0,0.26) !important;
}

/* ─── 8. SHINE EFFECT — passagem de luz mais premium ────────── */
.shine-effect::after {
  background: linear-gradient(
    to right,
    transparent 0%,
    rgba(255,255,255,0.030) 50%,
    transparent 100%
  ) !important;
}

/* ─── 9. INPUTS GLOBAIS — glass refinado ────────────────────── */
input:not([type="checkbox"]):not([type="radio"]):not([type="range"]):not([type="file"]):not([type="range"]),
select,
textarea {
  background: rgba(255,255,255,0.045) !important;
  border: 1px solid rgba(255,255,255,0.10) !important;
  border-radius: var(--r-xs) !important;
  color: rgba(255,255,255,0.92) !important;
  transition:
    border-color  0.20s ease,
    background    0.20s ease,
    box-shadow    0.20s ease !important;
}

input:not([type="checkbox"]):not([type="radio"]):not([type="range"]):not([type="file"]):focus,
select:focus,
textarea:focus {
  background:   rgba(255,255,255,0.065) !important;
  border-color: rgba(249,115,22,0.48) !important;
  box-shadow:   0 0 0 3px rgba(249,115,22,0.12),
                inset 0 1px 0 rgba(255,255,255,0.05) !important;
  outline: none !important;
}

/* override o bg-black dos inputs de login/modais */
#login-screen input,
#reset-password-screen input,
#modal-overlay input,
#modal-overlay select,
#client-modal-overlay input,
#fecha-venda-modal select,
#proposal-builder-modal input,
#proposal-builder-modal select {
  background: rgba(255,255,255,0.05) !important;
  border-color: rgba(255,255,255,0.12) !important;
}

/* search bar principal (override do bg-neutral-900 inline) */
#search-input {
  background: rgba(255,255,255,0.04) !important;
  border-width: 1px !important;
  border-color: rgba(255,255,255,0.10) !important;
}
#search-input:focus {
  background: rgba(255,255,255,0.06) !important;
  border-color: rgba(249,115,22,0.45) !important;
}

/* ─── 10. BOTÕES — arredondados e elevados ───────────────────── */
button:not(.chat-icon-btn):not(.chat-thread-send-btn):not(.vid-nav-btn):not(.chat-thread-meta-btn):not([class*="rounded-full"]) {
  border-radius: var(--r-xs) !important;
}

/* Botões CTA com gradiente — glow suave */
button[class*="from-orange"],
button[class*="from-green"] {
  border-radius: var(--r-sm) !important;
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.08),
    0 4px 16px rgba(249,115,22,0.20) !important;
  transition: all 0.20s ease !important;
}
button[class*="from-orange"]:hover {
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.12),
    0 6px 24px rgba(249,115,22,0.32),
    inset 0 1px 0 rgba(255,255,255,0.16) !important;
  transform: translateY(-1px) !important;
}
button[class*="from-green"]:hover {
  box-shadow:
    0 0 0 1px rgba(255,255,255,0.10),
    0 6px 24px rgba(34,197,94,0.28) !important;
  transform: translateY(-1px) !important;
}

/* ─── 11. BARRA PRINCIPAL DE BUSCA (toolbar) ─────────────────── */
#main-toolbar .relative.flex-1 {
  container-type: inline-size;
}
#view-toggle-container {
  background: rgba(255,255,255,0.04) !important;
  border: 1px solid rgba(255,255,255,0.07) !important;
  border-radius: var(--r-sm) !important;
  overflow: hidden;
}

/* ─── 12. ADMIN BAR — glass contexto alerta ──────────────────── */
#admin-bar {
  background: rgba(80,8,8,0.22) !important;
  backdrop-filter: blur(14px) !important;
  border: 1px solid rgba(239,68,68,0.12) !important;
  border-radius: var(--r-md) !important;
  box-shadow:
    0 4px 20px rgba(0,0,0,0.30),
    inset 0 1px 0 rgba(239,68,68,0.06) !important;
}

/* ─── 13. EMPTY STATE ────────────────────────────────────────── */
#empty-state {
  background: rgba(255,255,255,0.014) !important;
  backdrop-filter: blur(10px) !important;
  border: 1px dashed rgba(255,255,255,0.06) !important;
  border-radius: var(--r-lg) !important;
}
#empty-state-icon {
  background: rgba(255,255,255,0.04) !important;
  border: 1px solid rgba(255,255,255,0.07) !important;
  border-radius: var(--r-md) !important;
}

/* ─── 14. TELA DE LOGIN — painel premium flutuante ──────────── */
#login-screen {
  background:
    radial-gradient(ellipse 90% 60% at 50% -15%,
      rgba(249,115,22,0.07) 0%, transparent 60%),
    #09090c !important;
}
#login-screen > .relative.z-10 > div > .bg-neutral-900\/80,
#login-screen > div > div > .bg-neutral-900\/80 {
  background: linear-gradient(
    158deg,
    rgba(22,22,32,0.97) 0%,
    rgba(14,14,22,0.93) 100%
  ) !important;
  backdrop-filter: blur(40px) saturate(150%) !important;
  -webkit-backdrop-filter: blur(40px) saturate(150%) !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  border-radius: var(--r-xl) !important;
  box-shadow:
    0 0  0  1px rgba(255,255,255,0.024),
    0 32px 100px rgba(0,0,0,0.82),
    0  8px  32px rgba(0,0,0,0.60),
    0  0   60px rgba(249,115,22,0.04),
    inset 0  1px 0 rgba(255,255,255,0.10),
    inset 0 -1px 0 rgba(0,0,0,0.36) !important;
}

/* Reset de senha */
#reset-password-screen .bg-neutral-900\/80 {
  background: linear-gradient(
    158deg,
    rgba(22,22,32,0.97) 0%,
    rgba(14,14,22,0.93) 100%
  ) !important;
  backdrop-filter: blur(40px) saturate(150%) !important;
  -webkit-backdrop-filter: blur(40px) saturate(150%) !important;
  border: 1px solid rgba(255,255,255,0.08) !important;
  border-radius: var(--r-xl) !important;
  box-shadow:
    0 32px 100px rgba(0,0,0,0.80),
    0  8px  28px rgba(0,0,0,0.55),
    inset 0 1px 0 rgba(255,255,255,0.10) !important;
}

/* Loading bar splash */
#splash-screen .w-full.h-1\.5,
.w-full.h-1\.5.bg-neutral-900 {
  background: rgba(255,255,255,0.05) !important;
  border-color: rgba(255,255,255,0.07) !important;
  border-radius: 999px !important;
  overflow: hidden !important;
}

/* ─── 15. MODAL: ADMIN KIT ───────────────────────────────────── */
#modal-overlay > div {
  background: linear-gradient(
    158deg,
    rgba(20,20,30,0.98) 0%,
    rgba(12,12,20,0.97) 100%
  ) !important;
  border: 1px solid rgba(255,255,255,0.07) !important;
  border-radius: var(--r-xl) !important;
  overflow: hidden;
  box-shadow:
    0  0   0  1px rgba(255,255,255,0.022),
    0 32px 90px rgba(0,0,0,0.82),
    0  0  60px rgba(249,115,22,0.07),
    inset 0 1px 0 rgba(255,255,255,0.08) !important;
}

/* ─── 16. MODAL: NOVO CLIENTE ────────────────────────────────── */
#client-modal-overlay > div {
  background: linear-gradient(
    158deg,
    rgba(20,20,30,0.98) 0%,
    rgba(12,12,20,0.97) 100%
  ) !important;
  border: 1px solid rgba(255,255,255,0.07) !important;
  border-radius: var(--r-xl) !important;
  overflow: hidden;
  box-shadow:
    0 28px 80px rgba(0,0,0,0.80),
    0  0  50px rgba(249,115,22,0.06),
    inset 0 1px 0 rgba(255,255,255,0.07) !important;
}

/* ─── 17. MODAL: CONFIRMAÇÃO ─────────────────────────────────── */
#confirm-modal-overlay > div {
  background: linear-gradient(
    158deg,
    rgba(20,12,12,0.98) 0%,
    rgba(14,8,8,0.97) 100%
  ) !important;
  border: 1px solid rgba(255,255,255,0.06) !important;
  border-radius: var(--r-xl) !important;
  overflow: hidden;
  box-shadow:
    0 28px 80px rgba(0,0,0,0.80),
    0  0  40px rgba(239,68,68,0.07),
    inset 0 1px 0 rgba(255,255,255,0.06) !important;
}

/* ─── 18. MODAL: FECHAR VENDA ────────────────────────────────── */
#fecha-venda-modal > div {
  background: linear-gradient(
    180deg,
    rgba(10,15,12,0.99) 0%,
    rgba(8,12,10,0.98)  100%
  ) !important;
  border: 1px solid rgba(255,255,255,0.06) !important;
  border-radius: var(--r-xl) !important;
  overflow: hidden;
  box-shadow:
    0 32px 90px rgba(0,0,0,0.84),
    0  0  60px rgba(34,197,94,0.07),
    inset 0 1px 0 rgba(255,255,255,0.07) !important;
}

/* ─── 19. MODAL: PROPOSAL BUILDER ───────────────────────────── */
#proposal-builder-modal > div {
  background: linear-gradient(
    180deg,
    rgba(11,11,17,0.99) 0%,
    rgba(9,9,15,0.98)   100%
  ) !important;
  border: 1px solid rgba(255,255,255,0.06) !important;
  border-radius: var(--r-xl) !important;
  overflow: hidden;
  box-shadow:
    0  0   0  1px rgba(255,255,255,0.020),
    0 40px 120px rgba(0,0,0,0.90),
    0  0   80px rgba(249,115,22,0.05),
    inset 0 1px 0 rgba(255,255,255,0.07) !important;
}

/* Tab selectors dentro do proposal builder */
#proposal-builder-modal .flex.bg-neutral-900\/80,
#proposal-builder-modal .flex.bg-black,
#proposal-builder-modal .flex.bg-neutral-900,
#pb-mode-helper + .flex {
  background: rgba(255,255,255,0.038) !important;
  border: 1px solid rgba(255,255,255,0.07) !important;
  border-radius: var(--r-sm) !important;
  overflow: hidden;
}

/* Cabeçalhos de modais */
#modal-overlay .border-b,
#client-modal-overlay .border-b,
#fecha-venda-modal .border-b,
#proposal-builder-modal .border-b {
  border-bottom-color: rgba(255,255,255,0.048) !important;
  background: rgba(255,255,255,0.015) !important;
}

/* ─── 20. MODAL: ADMIN SETTINGS (renderizado por JS) ─────────── */
/* Mira o div glass gerado por admin.js */
#main-container .bg-neutral-900.border-2:first-child {
  border-radius: var(--r-xl) !important;
  border-color: rgba(239,68,68,0.15) !important;
}

/* ─── 21. TOAST ──────────────────────────────────────────────── */
#toast {
  background: linear-gradient(
    135deg,
    #ea580c 0%,
    #d97706 100%
  ) !important;
  border: 1px solid rgba(255,255,255,0.22) !important;
  border-radius: var(--r-md) !important;
  box-shadow:
    0  8px 36px rgba(234,88,12,0.36),
    0  0  60px rgba(234,88,12,0.14),
    inset 0 1px 0 rgba(255,255,255,0.24) !important;
  backdrop-filter: blur(20px) !important;
}
#toast > div.bg-black {
  background: rgba(0,0,0,0.28) !important;
  border-radius: var(--r-xs) !important;
  border: none !important;
}

/* ─── 22. TABLE ROWS ──────────────────────────────────────────── */
.table-row-hover {
  border-radius: var(--r-xs) !important;
  transition: background 0.18s ease !important;
}
.table-row-hover:hover {
  background: linear-gradient(
    90deg,
    rgba(249,115,22,0.052) 0%,
    rgba(249,115,22,0.020) 40%,
    transparent 80%
  ) !important;
  border-left-color: rgba(249,115,22,0.36) !important;
}

/* ─── 23. CARDS RENDERIZADOS POR JS ──────────────────────────── */
.client-metric-card,
.dash-metric-card {
  border-radius: var(--r-md) !important;
}

/* Items de lista admin */
#main-container .border.border-neutral-800 {
  border-radius: var(--r-sm) !important;
  border-color: rgba(255,255,255,0.06) !important;
  transition: border-color 0.2s ease, background 0.2s ease !important;
}
#main-container .border.border-neutral-800:hover {
  border-color: rgba(255,255,255,0.10) !important;
}
/* Itens com bg-neutral-900/60 border (admin) */
#main-container .bg-neutral-900\/60 {
  background: rgba(255,255,255,0.028) !important;
  border-color: rgba(255,255,255,0.06) !important;
}
#main-container .bg-neutral-900\/60:hover {
  background: rgba(255,255,255,0.042) !important;
}

/* Seção hero admin com grid */
section.bg-\[\#080808\].bg-grid {
  background-color: rgba(8,8,13,0.96) !important;
  border-radius: var(--r-md) !important;
  border-color: rgba(255,255,255,0.055) !important;
}

/* ─── 24. PROPOSAL BUILDER INTERNO ───────────────────────────── */
#pb-products-container,
#pb-section-financiamento,
#pb-section-historico,
#pb-equip-panel {
  background: rgba(9,9,15,0.88) !important;
}
#pb-promocional-toolbar {
  background: rgba(255,255,255,0.018) !important;
  border-bottom-color: rgba(255,255,255,0.048) !important;
}
#pb-equip-form .bg-neutral-900\/60 {
  background: rgba(255,255,255,0.030) !important;
  border-color: rgba(255,255,255,0.07) !important;
  border-radius: var(--r-sm) !important;
}

/* ─── 25. SCROLLBARS PREMIUM ──────────────────────────────────── */
::-webkit-scrollbar-track {
  background: rgba(255,255,255,0.018) !important;
  border-radius: 99px !important;
}
::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.085) !important;
  border-radius: 99px !important;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(249,115,22,0.42) !important;
}

/* ─── 26. CHAT SHELL ──────────────────────────────────────────── */
.chat-shell--desktop .chat-shell-window {
  background: rgba(10,10,16,0.97) !important;
  backdrop-filter: blur(32px) saturate(150%) !important;
  -webkit-backdrop-filter: blur(32px) saturate(150%) !important;
  border: 1px solid rgba(255,255,255,0.07) !important;
  border-radius: var(--r-lg) !important;
  box-shadow:
    0  0   0  1px rgba(255,255,255,0.022),
    0 24px 72px rgba(0,0,0,0.66),
    0  0  40px rgba(249,115,22,0.05) !important;
}
.chat-list-panel {
  background: rgba(255,255,255,0.015) !important;
}
.chat-search-wrap {
  border-bottom-color: rgba(255,255,255,0.042) !important;
}
.chat-thread-profile-card {
  background: rgba(14,14,22,0.97) !important;
  backdrop-filter: blur(20px) !important;
  border: 1px solid rgba(255,255,255,0.07) !important;
  border-radius: var(--r-md) !important;
  box-shadow: 0 16px 48px rgba(0,0,0,0.55) !important;
}
.chat-directory-card {
  background: rgba(12,12,18,0.97) !important;
  backdrop-filter: blur(24px) !important;
  border-color: rgba(255,255,255,0.06) !important;
  border-radius: var(--r-lg) !important;
}

/* ─── 27. VERSION UPDATE ──────────────────────────────────────── */
#version-update-notice {
  background: rgba(10,10,16,0.97) !important;
  backdrop-filter: blur(20px) !important;
  border: 1px solid rgba(249,115,22,0.28) !important;
  border-radius: var(--r-md) !important;
  box-shadow: 0 12px 48px rgba(249,115,22,0.16) !important;
}

/* ─── 28. SEÇÃO SECTION-ICON ──────────────────────────────────── */
.section-icon {
  border-radius: var(--r-xs) !important;
  background: rgba(255,255,255,0.045) !important;
}

/* ─── 29. FOCUS RING ──────────────────────────────────────────── */
*:focus-visible {
  outline: 2px solid rgba(249,115,22,0.52) !important;
  outline-offset: 2px !important;
}

/* ─── 30. SELECTION ───────────────────────────────────────────── */
::selection {
  background-color: rgba(249,115,22,0.30) !important;
  color: #fff !important;
}

/* ─── 31. BADGES GLOBAIS (spans como pílulas) ─────────────────── */
span[class*="px-"][class*="rounded"],
.metric-card span[class*="px-2"],
.client-metric-card span[class*="px-2"],
#main-container span[class*="border"][class*="text-"] {
  border-radius: 999px !important;
}

/* ─── 32. REDUCED MOTION ──────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .metric-card, .glass-card {
    transition: none !important;
  }
  body::before, body::after {
    display: none !important;
  }
  #app-content::before {
    display: none !important;
  }
}

/* ─── 33. MOBILE — economiza GPU ──────────────────────────────── */
@media (max-width: 768px) {
  body::before, body::after {
    display: none !important;
  }
  #app-content::before {
    display: none !important;
  }
  .metric-card {
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
    background: rgba(18,18,24,0.98) !important;
  }
}

/* ─── 34. LIGHT THEME OVERRIDE ────────────────────────────────── */
body.theme-light::before,
body.theme-light::after {
  display: none !important;
}
body.theme-light #app-content::before {
  display: none !important;
}
body.theme-light {
  background-color: #f0f4f8 !important;
}
body.theme-light .glass-card {
  background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%) !important;
  border: 1px solid rgba(0,0,0,0.07) !important;
  box-shadow:
    0 4px 20px rgba(0,0,0,0.07),
    inset 0 1px 0 rgba(255,255,255,0.90) !important;
  backdrop-filter: none !important;
}
body.theme-light .metric-card {
  background: linear-gradient(145deg, #ffffff 0%, #f8fafc 60%, #f1f5f9 100%) !important;
  border: 1px solid rgba(0,0,0,0.08) !important;
  box-shadow:
    0 2px 12px rgba(0,0,0,0.07),
    inset 0 1px 0 rgba(255,255,255,0.90) !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
}
body.theme-light header.sticky {
  background: rgba(248,250,252,0.97) !important;
  border-bottom-color: rgba(0,0,0,0.08) !important;
  box-shadow:
    0 1px 0 rgba(0,0,0,0.06),
    0 4px 24px rgba(0,0,0,0.10) !important;
}
body.theme-light #tab-container {
  background: rgba(0,0,0,0.04) !important;
  border-color: rgba(0,0,0,0.08) !important;
}
body.theme-light #tab-container button.tab-active-underline {
  background: linear-gradient(148deg, rgba(0,0,0,0.08), rgba(0,0,0,0.04)) !important;
  box-shadow: 0 1px 4px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,255,0.60) !important;
  color: #0f172a !important;
}
body.theme-light input:not([type="checkbox"]):not([type="radio"]):not([type="range"]):not([type="file"]),
body.theme-light select,
body.theme-light textarea {
  background: rgba(255,255,255,0.85) !important;
  border-color: rgba(0,0,0,0.14) !important;
  color: #0f172a !important;
}
body.theme-light input:focus,
body.theme-light select:focus,
body.theme-light textarea:focus {
  border-color: rgba(37,99,235,0.48) !important;
  box-shadow: 0 0 0 3px rgba(37,99,235,0.12) !important;
}
body.theme-light #toast {
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%) !important;
  box-shadow: 0 8px 36px rgba(37,99,235,0.35) !important;
}
body.theme-light #login-screen {
  background: linear-gradient(160deg, #f0f4f8 0%, #e2e8f0 100%) !important;
}
body.theme-light #login-screen > .relative.z-10 > div > .bg-neutral-900\/80,
body.theme-light #login-screen > div > div > .bg-neutral-900\/80,
body.theme-light #reset-password-screen .bg-neutral-900\/80 {
  background: linear-gradient(158deg, #ffffff 0%, #f8fafc 100%) !important;
  border-color: rgba(0,0,0,0.10) !important;
  box-shadow:
    0 32px 100px rgba(0,0,0,0.15),
    inset 0 1px 0 rgba(255,255,255,0.80) !important;
}

/* ============================================================
   END PREMIUM RESTYLING v2 LAYER
   ============================================================ */
